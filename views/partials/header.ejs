<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title><%= typeof title !== 'undefined' ? title : 'Hệ thống Quản lý OTP & Tài khoản' %></title>
    <!-- Script chặn nhấp nháy giao diện -->
    <script>
        (function() {
            var theme = localStorage.getItem('theme') || 'dark';
            if (theme === 'light') {
                document.documentElement.classList.add('light-theme');
            }
        })();
    </script>
    <!-- Bootstrap 5 CSS -->
    <link class="bootstrap-css" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom Modern Premium CSS -->
    <link rel="stylesheet" href="/css/modern-style.css" />
    <!-- Custom Site CSS -->
    <link rel="stylesheet" href="/css/site.css" />
    <% if (typeof useJqueryUi !== 'undefined' && useJqueryUi) { %>
        <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css" />
    <% } %>

    <!-- Shared Javascript Libraries (Loaded first to support page scripts) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <% if (typeof useJqueryUi !== 'undefined' && useJqueryUi) { %>
        <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui-touch-punch/0.2.3/jquery.ui.touch-punch.min.js"></script>
    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Script điều khiển sự kiện chuyển theme -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                var icon = toggleBtn.querySelector('i');
                
                // Cập nhật icon ban đầu dựa trên class light-theme của html
                if (document.documentElement.classList.contains('light-theme')) {
                    icon.className = 'fas fa-moon';
                } else {
                    icon.className = 'fas fa-sun';
                }
                
                toggleBtn.addEventListener('click', function() {
                    if (document.documentElement.classList.contains('light-theme')) {
                        document.documentElement.classList.remove('light-theme');
                        localStorage.setItem('theme', 'dark');
                        icon.className = 'fas fa-sun';
                    } else {
                        document.documentElement.classList.add('light-theme');
                        localStorage.setItem('theme', 'light');
                        icon.className = 'fas fa-moon';
                    }
                });
            }
        });
    </script>
</head>
<body>
    <!-- Premium Header Navbar -->
    <nav class="navbar navbar-expand-lg navbar-premium fixed-top">
        <div class="container">
            <a class="navbar-brand" href="<%= typeof slug !== 'undefined' && slug ? '/' + slug : '/' %>">
                <i class="fas fa-shield-alt brand-icon"></i>
                <span class="brand-text">Kim <span class="brand-accent">Tool</span></span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>" href="<%= typeof slug !== 'undefined' && slug ? '/' + slug : '/' %>">
                            <i class="fas fa-home nav-icon"></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>" href="<%= typeof slug !== 'undefined' && slug ? '/' + slug + '/Settings' : '/Settings' %>">
                            <i class="fas fa-cog nav-icon"></i> Cài đặt Hệ thống
                        </a>
                    </li>
                </ul>
                
                <div class="d-flex align-items-center gap-3">
                    <% if (settings && settings.enablePasswordProtection) { %>
                        <% if (authenticated) { %>
                            <a href="<%= typeof slug !== 'undefined' && slug ? '/' + slug + '/Settings#password-protection-card' : '/Settings#password-protection-card' %>" class="badge badge-status bg-success-glow text-decoration-none" title="Bấm để cài đặt bảo vệ">
                                <i class="fas fa-unlock-alt me-1"></i> Đã mở khóa
                            </a>
                            <form method="post" action="<%= typeof slug !== 'undefined' && slug ? '/' + slug + '/Login/Logout' : '/Login/Logout' %>" class="m-0">
                                <button type="submit" class="btn btn-navbar-logout btn-sm">
                                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                </button>
                            </form>
                        <% } else { %>
                            <a href="<%= typeof slug !== 'undefined' && slug ? '/' + slug + '/Settings#password-protection-card' : '/Settings#password-protection-card' %>" class="badge badge-status bg-danger-glow text-decoration-none" title="Bấm để cài đặt bảo vệ">
                                <i class="fas fa-lock me-1"></i> Đã khóa
                            </a>
                        <% } %>
                    <% } else { %>
                        <a href="<%= typeof slug !== 'undefined' && slug ? '/' + slug + '/Settings#password-protection-card' : '/Settings#password-protection-card' %>" class="badge badge-status bg-info-glow text-decoration-none" title="Bấm để cài đặt bảo vệ">
                            <i class="fas fa-shield-virus me-1"></i> Không khóa bảo vệ
                        </a>
                    <% } %>

                    <a class="btn-theme-toggle" href="https://www.facebook.com/trungkimphoto" target="_blank" title="Liên hệ Facebook">
                        <i class="fab fa-facebook"></i>
                    </a>

                    <button id="themeToggleBtn" class="btn-theme-toggle" title="Chuyển đổi giao diện Sáng/Tối">
                        <i class="fas fa-sun"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Container with standard padding to avoid overlap -->
    <main role="main" class="main-wrapper">
        <div class="container main-content-container">
